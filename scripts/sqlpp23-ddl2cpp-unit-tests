import io
import logging
import sys
import os
import unittest
import re
from importlib.machinery import SourceFileLoader

# Load the sqlpp23-ddl2cpp script as a module
script_path = os.path.join(os.path.dirname(__file__), 'sqlpp23-ddl2cpp')
ddl2cpp = SourceFileLoader('sqlpp23_ddl2cpp', script_path).load_module()

DdlParser = ddl2cpp.DdlParser
DdlExecutor = ddl2cpp.DdlExecutor
ModelWriter = ddl2cpp.ModelWriter
ExitCode = ddl2cpp.ExitCode

class SelfTest(unittest.TestCase):
    """Runs a unit tests of the parser"""

    @classmethod
    def setUpClass(cls):
        DdlParser.initialize()

    def test_base_types(self):
        for t in ddl2cpp.DdlParser.base_sql_type_to_cpp:
            with self.subTest(t=t):
                result = ddl2cpp.DdlParser.ddl_type.parse_string(t, parse_all=True)
                self.assertEqual(result[0], ddl2cpp.DdlParser.base_sql_type_to_cpp[t])

    def test_type_unknown(self):
        for t in ["cheesecake", "blueberry"]:
            with self.subTest(t=t):
                result = ddl2cpp.DdlParser.ddl_type.parse_string(t, parse_all=True)
                self.assertEqual(result[0], "UNKNOWN")

    def test_custom_type(self):
        DdlParser.initialize({"MY_TYPE_A": "my_custom_base", "MY_TYPE_B": "my::Type"})
        result = ddl2cpp.DdlParser.ddl_type.parse_string("MY_TYPE_A", parse_all=True)
        self.assertEqual(result[0], "my_custom_base")
        result = ddl2cpp.DdlParser.ddl_type.parse_string("MY_TYPE_B", parse_all=True)
        self.assertEqual(result[0], "my::Type")

    def test_column(self):
        test_data = [
            {
                "text": "\"id\" int(8) unsigned NOT NULL DEFAULT nextval('dk_id_seq'::regclass)",
                "expected": {
                    "name": "id",
                    "cpp_type": "::sqlpp::integral",
                    "is_unsigned": True,
                    "not_null": True,
                    "has_auto_value": False,
                    "has_default_value": True,
                    "has_generated_value": False,
                    "is_primary_key": False,
                    "is_array": False,
                }
            },
            {
                "text": "'fld' int AUTO_INCREMENT",
                "expected": {
                    "name": "fld",
                    "cpp_type": "::sqlpp::integral",
                    "is_unsigned": False,
                    "not_null": False,
                    "has_auto_value": True,
                    "has_default_value": False,
                    "has_generated_value": False,
                    "is_primary_key": False,
                    "is_array": False,
                }
            },
            {
                "text": "other_field int8 AUTOINCREMENT NOT NULL",
                "expected": {
                    "name": "other_field",
                    "cpp_type": "::sqlpp::integral",
                    "is_unsigned": False,
                    "not_null": True,
                    "has_auto_value": True,
                    "has_default_value": False,
                    "has_generated_value": False,
                    "is_primary_key": False,
                    "is_array": False,
                }
            },
            {
                "text": "\"new_field\" INT UNSIGNED PRIMARY KEY",
                "expected": {
                    "name": "new_field",
                    "cpp_type": "::sqlpp::integral",
                    "is_unsigned": True,
                    "not_null": False,
                    "has_auto_value": False,
                    "has_default_value": False,
                    "has_generated_value": False,
                    "is_primary_key": True,
                    "is_array": False,
                }
            },
            {
                "text": "'fld2' int NOT NULL GENERATED ALWAYS AS abc+1",
                "expected": {
                    "name": "fld2",
                    "cpp_type": "::sqlpp::integral",
                    "is_unsigned": False,
                    "not_null": True,
                    "has_auto_value": False,
                    "has_default_value": False,
                    "has_generated_value": True,
                    "is_primary_key": False,
                    "is_array": False,
                }
            },
            {
                "text": "int_array int8[] AUTOINCREMENT NOT NULL",
                "expected": {
                    "name": "int_array",
                    "cpp_type": "::sqlpp::integral",
                    "is_unsigned": False,
                    "not_null": True,
                    "has_auto_value": True,
                    "has_default_value": False,
                    "has_generated_value": False,
                    "is_primary_key": False,
                    "is_array": True,
                }
            },
        ]
        for td in test_data:
            with self.subTest(text=td["text"]):
                result = ddl2cpp.DdlParser.ddl_column.parse_string(td["text"], parse_all=True)[0]
                self.assertColumnMatches(result, td["expected"], td["text"])

    def assertColumnMatches(self, column_expr, column_expected, text):
        for field, expected_value in column_expected.items():
            with self.subTest(field=field):
                actual_value = getattr(column_expr, field)
                if isinstance(expected_value, bool):
                    actual_value = bool(actual_value)
                self.assertEqual(actual_value, expected_value, f"Field '{field}' mismatch for column expression: {text}")

    def test_constraint(self):
        for text in [
            "CONSTRAINT unique_person UNIQUE (first_name, last_name)",
            "UNIQUE (id)",
            "UNIQUE (first_name,last_name)"
        ]:
            with self.subTest(text=text):
                result = ddl2cpp.DdlParser.ddl_constraint.parse_string(text, parse_all=True)
                self.assertTrue(result.is_constraint)

    def test_math_expression(self):
            text = "2 DIV 2"
            result = ddl2cpp.DdlParser.ddl_expression.parse_string(text, parse_all=True)
            self.assertEqual(len(result), 3)
            self.assertEqual(result[0], "2")
            self.assertEqual(result[1], "DIV")
            self.assertEqual(result[2], "2")

    def test_rational(self):
        for text in [
            "pos RATIONAL NOT NULL DEFAULT nextval('rational_seq')::integer",
        ]:
            with self.subTest(text=text):
                result = ddl2cpp.DdlParser.ddl_column.parse_string(text, parse_all=True)
                column = result[0]
                self.assertEqual(column.name, "pos")
                self.assertEqual(column.cpp_type, "::sqlpp::text")
                self.assertTrue(column.not_null)

    def test_parse_valid_custom_types(self):
        csv_data = (
            "type,INT2,::my_project::int16_t\n"
            "column,users.id,::my_project::user_id_t\n"
        )
        fake_file = io.StringIO(csv_data)

        sql_type_to_cpp, column_to_cpp_type = ddl2cpp.get_custom_types("<string>", fake_file)

        self.assertEqual(sql_type_to_cpp.get("INT2"), "::my_project::int16_t")
        self.assertEqual(column_to_cpp_type.get("USERS.ID"), "::my_project::user_id_t")

    def test_invalid_row_type_raises_runtime_error(self):
        invalid_csv_data = "invalid_marker,some_entity,some_cpp_type\n"
        fake_file = io.StringIO(invalid_csv_data)

        with self.assertLogs(level='ERROR') as cm_logs:
            with self.assertRaises(SystemExit) as e:
                ddl2cpp.get_custom_types("<string>", fake_file)
            self.assertEqual(e.exception.code, ddl2cpp.ExitCode.BAD_CUSTOM_TYPES)
        self.assertTrue(any("Unknown row type in <string>: invalid_marker" in output for output in cm_logs.output))

    def test_bad_format_raises_runtime_error(self):
        invalid_csv_data = "type,some_entity\n"
        fake_file = io.StringIO(invalid_csv_data)

        with self.assertLogs(level='ERROR') as cm_logs:
            with self.assertRaises(SystemExit) as e:
                ddl2cpp.get_custom_types("<string>", fake_file)
            self.assertEqual(e.exception.code, ddl2cpp.ExitCode.BAD_CUSTOM_TYPES)
        self.assertTrue(any("Malformed CSV: Missing column 'cpp_type'" in output for output in cm_logs.output))

    def test_command_create_table(self):
        input_text = """
            CREATE TABLE "public"."dk" (
                id int8 NOT NULL DEFAULT nextval('dk_id_seq'::regclass),
                "strange" NUMERIC(314, 15),
                "last_update" timestamp(6) DEFAULT now(),
                PRIMARY KEY (id)
            )
        """
        result = ddl2cpp.DdlParser.ddl.parse_string(input_text, parse_all=True)
        self.assertEqual(len(result), 1)
        create_table = result[0]
        self.assertTrue(create_table.create_table)
        self.assertEqual(create_table.table_name, "public.dk")
        column_data = [
            {
                "name": "id",
                "cpp_type": "::sqlpp::integral",
                "is_unsigned": False,
                "not_null": True,
                "has_auto_value": False,
                "has_default_value": True,
                "has_generated_value": False,
                "is_primary_key": False,
                "is_array": False,
            },
            {
                "name": "strange",
                "cpp_type": "::sqlpp::floating_point",
                "is_unsigned": False,
                "not_null": False,
                "has_auto_value": False,
                "has_default_value": False,
                "has_generated_value": False,
                "is_primary_key": False,
                "is_array": False,
            },
            {
                "name": "last_update",
                "cpp_type": "::sqlpp::timestamp",
                "is_unsigned": False,
                "not_null": False,
                "has_auto_value": False,
                "has_default_value": True,
                "has_generated_value": False,
                "is_primary_key": False,
                "is_array": False,
            },
        ]
        self.assertEqual(len(create_table.columns), len(column_data))
        for index, expected in enumerate(column_data):
            with self.subTest(index=index, expected=expected):
                self.assertColumnMatches(create_table.columns[index], expected, "row: " + str(index))
        self.assertEqual(create_table.command_text, input_text.strip())

    def test_command_set_default(self):
        input_text = """ALTER TABLE ONLY mytbl ALTER COLUMN mycol SET DEFAULT 123"""
        result = ddl2cpp.DdlParser.ddl.parse_string(input_text, parse_all=True)
        self.assertEqual(len(result), 1)
        set_default = result[0]
        self.assertTrue(set_default.set_default)
        self.assertEqual(set_default.table_name, "mytbl")
        self.assertEqual(set_default.column_name, "mycol")

        # Schema-qualified table name
        input_text = """ALTER TABLE ONLY public.mytbl ALTER COLUMN mycol SET DEFAULT 123"""
        result = ddl2cpp.DdlParser.ddl.parse_string(input_text, parse_all=True)
        self.assertTrue(result[0].set_default)
        self.assertEqual(result[0].table_name, "public.mytbl")
        self.assertEqual(result[0].column_name, "mycol")

    def test_command_comment_on_column(self):
        # Without schema prefix
        result = ddl2cpp.DdlParser.ddl.parse_string(
            "COMMENT ON COLUMN t.x IS 'some note'", parse_all=True)
        self.assertTrue(result[0].comment_on_column)
        self.assertEqual(result[0].qualified_column, "t.x")
        self.assertFalse(getattr(result[0], 'cpp_type', None)) # cpp_type is not a field in the parser result

        # With schema prefix and cpp_type anywhere in the comment string
        result = ddl2cpp.DdlParser.ddl.parse_string(
            "COMMENT ON COLUMN public.t.x IS 'note cpp_type:MyType (extra)'", parse_all=True)
        self.assertTrue(result[0].comment_on_column)
        self.assertEqual(result[0].qualified_column, "public.t.x")
        self.assertEqual(result[0].column_comment, "note cpp_type:MyType (extra)")

    def test_model_writer(self):
        import argparse

        def make_args(**kwargs):
            return argparse.Namespace(**kwargs)

        # Test naming_style camel-case
        args = make_args(naming_style='camel-case')
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("name", args), "Name")
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("_name", args), "Name")
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("name part", args), "NamePart")
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("name_part", args), "NamePart")
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("name_part_part", args), "NamePartPart")
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("name2part_part3part", args), "Name2PartPart3Part")
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("schema.name", args), "SchemaName")
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("schema.name_part", args), "SchemaNamePart")

        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("name", args), "name")
        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("_name", args), "Name")
        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("name_part", args), "namePart")
        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("name part", args), "namePart")
        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("name_part_part", args), "namePartPart")
        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("name2part_part3part", args), "name2PartPart3Part")
        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("schema.name", args), "schemaName")
        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("schema.name_part", args), "schemaNamePart")

        # Test naming_style identity
        args = make_args(naming_style='identity')
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("name", args), "name")
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("_name", args), "_name")
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("name_part", args), "name_part")
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("name part", args), "name_part")
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("name_part_part", args), "name_part_part")
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("name2part_part3part", args), "name2part_part3part")
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("schema.name", args), "schema_name")
        self.assertEqual(ddl2cpp.ModelWriter._to_class_name("schema.name_part", args), "schema_name_part")

        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("name", args), "name")
        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("_name", args), "_name")
        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("name_part", args), "name_part")
        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("name part", args), "name_part")
        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("name_part_part", args), "name_part_part")
        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("name2part_part3part", args), "name2part_part3part")
        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("schema.name", args), "schema_name")
        self.assertEqual(ddl2cpp.ModelWriter._to_member_name("schema.name_part", args), "schema_name_part")

    def test_cpp_type_executor(self):
        import argparse

        def make_args(**kwargs):
            defaults = dict(assume_auto_id=False, suppress_timestamp_warning=True, strip_sql_schema=None)
            defaults.update(kwargs)
            return argparse.Namespace(**defaults)

        # Unsigned int
        with self.subTest("unsigned integral"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string(
                "CREATE TABLE t (x bigint unsigned NOT NULL)", parse_all=True)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["x"].cpp_type, "::sqlpp::unsigned_integral")

        # Unsigned int
        with self.subTest("unsigned integral overridden by signed integral"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string(
                    "CREATE TABLE t (-- cpp_type:::sqlpp::integral\n x bigint unsigned NOT NULL)", parse_all=True)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["x"].cpp_type, "::sqlpp::integral")

        # Annotation directly before the column
        with self.subTest("Annotation directly before the column"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string(
                "CREATE TABLE t (-- cpp_type:MyType\n x bigint NOT NULL)", parse_all=True)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["x"].cpp_type, "MyType")

        # Annotation anywhere in the comment line with surrounding text
        with self.subTest("Annotation anywhere in the comment line with surrounding text"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string(
                "CREATE TABLE t (-- note cpp_type:MyType (extra info)\n x bigint NOT NULL)", parse_all=True)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["x"].cpp_type, "MyType")

        # Regular comment without cpp_type: does not set cpp_type
        with self.subTest("Regular comment without cpp_type"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string(
                "CREATE TABLE t (-- regular comment\n x bigint NOT NULL)", parse_all=True)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["x"].cpp_type, "::sqlpp::integral")

        # MySQL-style COMMENT clause: value is captured
        with self.subTest("MySQL-style COMMENT clause"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string(
                "CREATE TABLE t (x int DEFAULT NULL COMMENT 'cpp_type:my::Type')", parse_all=True)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["x"].cpp_type, "my::Type")

        # Matching cpp_type from annotation and comment:
        with self.subTest("Matching cpp_type from annotation and comment"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string(
                "CREATE TABLE t (-- cpp_type:my::Type\n x bigint NOT NULL COMMENT 'cpp_type:my::Type')", parse_all=True)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["x"].cpp_type, "my::Type")

        # Non-matching cpp_type from annotation and comment:
        with self.subTest("Non-matching cpp_type from annotation and comment"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string(
                "CREATE TABLE t (-- cpp_type:Something\n x bigint NOT NULL COMMENT 'cpp_type:Else')", parse_all=True)
            with self.assertLogs(level='ERROR') as cm_logs:
                with self.assertRaises(SystemExit) as cm:
                    ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
                self.assertEqual(cm.exception.code, ddl2cpp.ExitCode.BAD_COLUMN_ANNOTATION)
            self.assertTrue(any("Something" in output for output in cm_logs.output))
            self.assertTrue(any("Else" in output for output in cm_logs.output))

        # Trailing comments are ignored
        with self.subTest("Trailing comments are ignored"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE t (
                    a bigint PRIMARY KEY
                    -- Inline column constraint is processed here
                    -- Multiple trailing comments are perfectly OK
                    ,
                    b bigint NOT NULL,
                    c numeric(10, 2)
                    -- Trailing comments are OK with cpp_type:Something
                    -- Trailing comments are OK without type
            );
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["a"].cpp_type, "::sqlpp::integral")
            self.assertEqual(tables["t"].columns["b"].cpp_type, "::sqlpp::integral")
            self.assertEqual(tables["t"].columns["c"].cpp_type, "::sqlpp::floating_point")

        # Non-annotation colons are ignored
        with self.subTest("Non-annotation colons are ignored"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE t(
                  -- FIXME: We should really make this cpp_type:animal further down the road
                  animal bigint
                );
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["animal"].cpp_type, "animal")

        # In-type comments are ignored
        with self.subTest("In-type comments are ignored"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE t (
                    a
                        -- in-type comments are ignored, even with cpp_type:Something
                        bigint PRIMARY KEY
                    ,
                    b bigint NOT
                        -- comments can even break up NOT NULL
                        NULL
                        -- in-type comments are ignored, even with cpp_type:Something
                        DEFAULT 3,
                    c numeric(10, 2)
            );
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["a"].cpp_type, "::sqlpp::integral")
            self.assertEqual(tables["t"].columns["b"].cpp_type, "::sqlpp::integral")
            self.assertEqual(tables["t"].columns["c"].cpp_type, "::sqlpp::floating_point")

        # Leading, inline, and trailing comments are ignored for constraints
        with self.subTest("Leading, inline, and trailing comments are ignored for constraints"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE t (
                    a bigint NOT NULL,
                    b bigint NOT NULL,
                    c varchar(255),

                    -- Now testing table-level constraints:
                    -- Leading comments are ignored, even with cpp_type:Something
                    FOREIGN KEY (user_id)
                        -- in-constraint comments are ignored, even with cpp_type:Something
                        REFERENCES users (id),
                    -- A named unique constraint block
                    CONSTRAINT unique_service_env UNIQUE (service_id, environment_id)
                    -- The trailing block here safely ignores this comment text
                    -- And finishes cleanly right before the comma or parenthesis,
                );
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["a"].cpp_type, "::sqlpp::integral")
            self.assertEqual(tables["t"].columns["b"].cpp_type, "::sqlpp::integral")
            self.assertEqual(tables["t"].columns["c"].cpp_type, "::sqlpp::text")

        # Annotations and custom type mappings to ::sqlpp::serial
        with self.subTest("Annotations and custom type mappings to ::sqlpp::serial"):
            DdlParser.initialize({"B": "sqlpp::serial"})
            parsed = ddl2cpp.DdlParser.ddl.parse_string(
                    """CREATE TABLE t (
                    -- cpp_type:sqlpp::serial
                    s1 A NOT NULL,
                    s2 B NOT NULL,
                    s3 C NOT NULL,
                    s4 bigint NOT NULL
                    )
                    """, parse_all=True)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {"S3": "::sqlpp::serial"})
            self.assertEqual(tables["t"].columns["s1"].cpp_type, "sqlpp::serial")
            self.assertEqual(tables["t"].columns["s2"].cpp_type, "sqlpp::serial")
            self.assertEqual(tables["t"].columns["s3"].cpp_type, "::sqlpp::serial")
            self.assertEqual(tables["t"].columns["s4"].cpp_type, "::sqlpp::integral")

            self.assertTrue(tables["t"].columns["s1"].has_default)
            self.assertTrue(tables["t"].columns["s2"].has_default)
            self.assertTrue(tables["t"].columns["s3"].has_default)
            self.assertFalse(tables["t"].columns["s4"].has_default)

        # Leading inline comment before a column sets cpp_type
        with self.subTest("Leading inline comment before a column sets cpp_type"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE t (
                    -- cpp_type:MyAType
                    a
                    -- in-column comments are OK, cpp_type:Something
                    bigint NOT NULL
                    -- Trailing comments are OK, cpp_type:Something
                    -- Trailing comments are OK without type
                    ,
                    -- cpp_type:MyBType
                    b text NOT NULL
                      -- in-type comment without type
                      -- in-type comment with cpp_type:Something
                      DEFAULT "",
                    c text NOT NULL,
                    -- cpp_type:MyDType
                    d text NOT NULL
                    -- Trailing comments are OK without type
                    -- Trailing comments are OK with cpp_type:Something
                )
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["a"].cpp_type, "MyAType")
            self.assertEqual(tables["t"].columns["b"].cpp_type, "MyBType")
            self.assertEqual(tables["t"].columns["c"].cpp_type, "::sqlpp::text")
            self.assertEqual(tables["t"].columns["d"].cpp_type, "MyDType")

        # COMMENT ON COLUMN sets cpp_type (schema is stripped via --strip-sql-schema)
        with self.subTest("COMMENT ON COLUMN sets cpp_type"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE public.t (a bigint NOT NULL)
                COMMENT ON COLUMN public.t.a IS 'cpp_type:MyType'
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(strip_sql_schema="public"), {})
            self.assertEqual(tables["t"].columns["a"].cpp_type, "MyType")

        # COMMENT ON COLUMN has to match inline comment
        with self.subTest("COMMENT ON COLUMN has to match inline comment"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE public.t (
                    -- cpp_type:SharedType
                    a bigint NOT NULL
                )
                COMMENT ON COLUMN public.t.a IS 'cpp_type:SharedType'
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(strip_sql_schema="public"), {})
            self.assertEqual(tables["t"].columns["a"].cpp_type, "SharedType")

        # COMMENT ON COLUMN has to match inline comment, also with some quoted identifiers
        with self.subTest("COMMENT ON COLUMN has to match inline comment, with quoted identifiers"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE "public".t (
                    -- cpp_type:SharedType
                    a bigint NOT NULL
                )
                COMMENT ON COLUMN "public"."t"."a" IS 'cpp_type:SharedType'
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(strip_sql_schema="public"), {})
            self.assertEqual(tables["t"].columns["a"].cpp_type, "SharedType")

        # COMMENT ON COLUMN mismatch
        with self.subTest("COMMENT ON COLUMN mismatch"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE public.t (
                    -- cpp_type:InlineType
                    a bigint NOT NULL
                )
                COMMENT ON COLUMN public.t.a IS 'cpp_type:CommentType'
            """)
            with self.assertLogs(level='ERROR') as cm_logs:
                with self.assertRaises(SystemExit) as cm:
                    ddl2cpp.DdlExecutor.execute([parsed], make_args(strip_sql_schema="public"), {})
                self.assertEqual(cm.exception.code, ddl2cpp.ExitCode.BAD_COLUMN_ANNOTATION)
            self.assertTrue(any("InlineType" in output for output in cm_logs.output))
            self.assertTrue(any("CommentType" in output for output in cm_logs.output))

        # Comment annotations override --path-to-custom-type-mapping type mapping
        with self.subTest("Comment annotations override --path-to-custom-type-mapping type mapping"):
            DdlParser.initialize({"MY_A": "my::TypeA"})
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE public.t (
                    -- cpp_type:CommentType
                    a MY_A NOT NULL
                )
                COMMENT ON COLUMN public.t.a IS 'cpp_type:CommentType'
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["public.t"].columns["a"].cpp_type, "CommentType")

        # --path-to-custom-type-mapping column mappings overrides both inline comment and COMMENT ON COLUMN
        with self.subTest("-path-to-custom-type-mapping column mappings overrides both inline comment and COMMENT ON COLUMN"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE public.t (
                    -- cpp_type:SharedType
                    a bigint NOT NULL
                )
                COMMENT ON COLUMN public.t.a IS 'cpp_type:SharedType'
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {"A": "CsvType"})
            self.assertEqual(tables["public.t"].columns["a"].cpp_type, "CsvType")

        # --path-to-custom-type-mapping table.column overrides column mapping
        with self.subTest("--path-to-custom-type-mapping table.column overrides column mapping"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE public.t (
                    -- cpp_type:SharedType
                    a bigint NOT NULL
                )
                COMMENT ON COLUMN public.t.a IS 'cpp_type:SharedType'
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {"A": "Column", "T.A": "TableColumn"})
            self.assertEqual(tables["public.t"].columns["a"].cpp_type, "TableColumn")

        # --path-to-custom-type-mapping schema.table.column overrides table.column mapping
        with self.subTest("--path-to-custom-type-mapping schema.table.column overrides table.column mapping overrides others"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE public.t (
                    -- cpp_type:SharedType
                    a bigint NOT NULL
                )
                COMMENT ON COLUMN public.t.a IS 'cpp_type:SharedType'
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {"T.A": "TableColumn", "PUBLIC.T.A": "SchemaTableColumn"})
            self.assertEqual(tables["public.t"].columns["a"].cpp_type, "SchemaTableColumn")

        # --path-to-custom-type-mapping schema.table.column is case insensitive
        with self.subTest("--path-to-custom-type-mapping schema.table.column is case insensitive"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE public.t (
                    -- cpp_type:SharedType
                    a bigint NOT NULL
                )
                COMMENT ON COLUMN public.t.a IS 'cpp_type:SharedType'
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {"PUBLIC.T.A": "SchemaTableColumn"})
            self.assertEqual(tables["public.t"].columns["a"].cpp_type, "SchemaTableColumn")

        # MySQL COMMENT clause: cpp_type extracted from column comment
        with self.subTest("MySQL COMMENT clause"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string(
                "CREATE TABLE t (x int DEFAULT NULL COMMENT 'cpp_type:my::Type')")
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["x"].cpp_type, "my::Type")

        # Unknown SQL type resolved by cpp_type annotation
        with self.subTest("Unknown SQL type resolved by cpp_type annotation"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE t (
                    -- cpp_type:MyUuidType
                    id uuid NOT NULL
                )
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["id"].cpp_type, "MyUuidType")

        # Annotation with qualified vs unqualified type
        with self.subTest("Annotation with qualified vs unqualified type"):
            import io
            from contextlib import redirect_stdout

            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE t (
                    -- cpp_type:my::Type
                    a bigint NOT NULL,
                    -- cpp_type:unqualified_type
                    b bigint NOT NULL
                )
            """, parse_all=True)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["a"].cpp_type, "my::Type")
            self.assertEqual(tables["t"].columns["b"].cpp_type, "unqualified_type")

        # Mapping with qualified vs unqualified type
        with self.subTest("Mapping with qualified vs unqualified type"):
            import io
            from contextlib import redirect_stdout

            # Re-initialize with custom mappings
            DdlParser.initialize({"MY_TYPE_A": "my::Type", "MY_TYPE_B": "unqualified_type"})
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE t (
                    a MY_TYPE_A NOT NULL,
                    b MY_TYPE_B NOT NULL
                )
            """, parse_all=True)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertEqual(tables["t"].columns["a"].cpp_type, "my::Type")
            self.assertEqual(tables["t"].columns["b"].cpp_type, "unqualified_type")

        # Schema-qualified ALTER TABLE resolved with --strip-sql-schema
        with self.subTest("Schema-qualified ALTER TABLE resolved with --strip-sql-schema"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE public.t (a bigint NOT NULL)
                ALTER TABLE ONLY public.t ALTER COLUMN a SET DEFAULT 42
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(strip_sql_schema="public"), {})
            self.assertTrue(tables["t"].columns["a"].has_default)

        # Schema-qualified ALTER TABLE resolved without --strip-sql-schema
        with self.subTest("Schema-qualified ALTER TABLE resolved without --strip-sql-schema"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE "public".t (a bigint NOT NULL);
                ALTER TABLE ONLY "public".t ALTER COLUMN a SET DEFAULT 42
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(), {})
            self.assertTrue(tables["public.t"].columns["a"].has_default)

        # Schema-qualified ALTER TABLE resolved with --strip-sql-schema and quoted table name
        with self.subTest("Schema-qualified ALTER TABLE resolved with --strip-sql-schema and quoted table"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE public.t (a bigint NOT NULL)
                ALTER TABLE ONLY "public".t ALTER COLUMN a SET DEFAULT 42
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(strip_sql_schema="public"), {})
            self.assertTrue(tables["t"].columns["a"].has_default)

        # Unknown ALTER TABLE commands get ignored
        with self.subTest("Unknown ALTER TABLE commands get ignored"):
            parsed = ddl2cpp.DdlParser.ddl.parse_string("""
                CREATE TABLE public.t (a bigint NOT NULL)
                ALTER TABLE tbl_b ADD FOREIGN KEY (id) REFERENCES tbl_a (id);
            """)
            tables = ddl2cpp.DdlExecutor.execute([parsed], make_args(strip_sql_schema="public"), {})


if __name__ == "__main__":
    logging.basicConfig(format='%(levelname)s: %(message)s', level=logging.INFO)
    unittest.main()
